import { Hono } from 'hono';
import { cors } from 'hono/cors';
import { generatePollinations } from './adapters/pollinations.ts';
import { generateKie } from './adapters/kie.ts';

const app = new Hono();
app.use('/*', cors());

const taskStore = new Map<string, { imageUrl?: string; error?: string; done: boolean }>();
setInterval(() => { if (taskStore.size > 100) { const keys = [...taskStore.keys()].slice(0, 50); keys.forEach(k => taskStore.delete(k)); } }, 10 * 60_000);

const rateLimitMap = new Map<string, { count: number; resetAt: number }>();
const RATE_LIMIT = 5;
const WINDOW_MS = 60_000;
function checkRateLimit(ip: string): boolean {
  const now = Date.now();
  const entry = rateLimitMap.get(ip);
  if (!entry || now > entry.resetAt) { rateLimitMap.set(ip, { count: 1, resetAt: now + WINDOW_MS }); return true; }
  if (entry.count >= RATE_LIMIT) return false;
  entry.count++;
  return true;
}
setInterval(() => { const now = Date.now(); for (const [ip, entry] of rateLimitMap.entries()) { if (now > entry.resetAt) rateLimitMap.delete(ip); } }, 5 * 60_000);

app.post('/callback', async (c) => {
  try {
    const body = await c.req.json();
    console.log('[CALLBACK] FULL:', JSON.stringify(body).slice(0, 2000));
    const taskId = body.data?.taskId || body.taskId;
    if (!taskId) return c.json({ ok: false }, 400);
    const status = body.data?.state || body.data?.status || body.status;
    if (status === 'SUCCESS' || status === 'success' || status === 'completed') {
      // Kie.ai returneaza URL in data.resultJson (string JSON)
      let imgUrl = body.data?.output?.[0]?.url || body.data?.result?.[0]?.url;
      if (!imgUrl && body.data?.resultJson) {
        try {
          const rj = JSON.parse(body.data.resultJson);
          imgUrl = rj.resultUrls?.[0] || rj.images?.[0] || rj.url;
        } catch(e) {}
      }
      if (imgUrl) {
        console.log(`[CALLBACK] Task ${taskId} SUCCESS, downloading...`);
        const imgRes = await fetch(imgUrl);
        const buf = await imgRes.arrayBuffer();
        const b64 = Buffer.from(buf).toString('base64');
        const ext = imgUrl.includes('.png') ? 'png' : 'jpeg';
        taskStore.set(taskId, { imageUrl: `data:image/${ext};base64,${b64}`, done: true });
        console.log(`[CALLBACK] Task ${taskId} stored OK`);
      }
    } else if (status === 'FAILED' || status === 'failed') {
      taskStore.set(taskId, { error: 'Generation failed', done: true });
    }
    return c.json({ ok: true });
  } catch (err: any) {
    console.error('[CALLBACK] Error:', err.message);
    return c.json({ ok: false }, 500);
  }
});

app.get('/status/:taskId', (c) => {
  const taskId = c.req.param('taskId');
  const task = taskStore.get(taskId);
  if (!task) return c.json({ done: false, waiting: true });
  return c.json(task);
});

app.post('/generate', async (c) => {
  const ip = c.req.header('x-forwarded-for')?.split(',')[0].trim() || c.req.header('x-real-ip') || 'unknown';
  if (!checkRateLimit(ip)) {
    console.log(`[RATE LIMIT] Blocat IP: ${ip}`);
    return c.json({ error: 'Prea multe cereri. Incearca din nou peste un minut.' }, 429);
  }
  try {
    const body = await c.req.json();
    const { prompt, referenceImages = [], dishName } = body;
    console.log(`[GENERATE] IP: ${ip} | dish: ${dishName || 'N/A'}`);
    const kieKey = process.env.KIE_AI_KEY;
    if (kieKey) {
      try {
        const { taskId } = await generateKie(prompt || '', referenceImages, kieKey, 'https://mrdelivery.shop');
        console.log(`[GENERATE] Kie task: ${taskId}, waiting callback max 90s...`);
        for (let i = 0; i < 90; i++) {
          await new Promise(r => setTimeout(r, 1000));
          const task = taskStore.get(taskId);
          if (task?.done) {
            if (task.imageUrl) { console.log(`[GENERATE] Kie done after ${i+1}s`); return c.json({ imageUrl: task.imageUrl, provider: 'Kie.ai nano-banana-2' }); }
            throw new Error(task.error || 'Kie failed');
          }
        }
        console.log('[GENERATE] Kie timeout -> Pollinations fallback');
      } catch (kieErr: any) {
        console.error('[GENERATE] Kie error:', kieErr.message);
      }
    }
    const result = await generatePollinations(prompt || '');
    return c.json({ imageUrl: result.imageUrl, provider: 'Pollinations.ai' });
  } catch (err: any) {
    return c.json({ error: err.message }, 500);
  }
});

const port = parseInt(process.env.PORT || '4900');
console.log(`MrDelivery Proxy on http://localhost:${port}`);
export default { port, fetch: app.fetch };
