export const STYLE_PROMPTS: Record<string, string> = {
  'Pizza Overhead': `CAMERA: Strictly 90-degree overhead bird's eye. LIGHTING: Soft diffused 5500K daylight. SURFACE: Rustic dark wood pizza board. CHEESE: Bubbling golden mozzarella. CRUST: Leoparding visible. PHYSICS & REALISM: Pizza rests naturally on surface with visible contact shadow. Zero floating elements. 100% photorealistic. MOOD: Italian trattoria premium.`,
  'Burger Hero Shot': `CAMERA: 15-22 degree low angle. LIGHTING: 3200K warm tungsten. SURFACE: Dark slate. LAYERS: All visible. PHYSICS & REALISM: Burger rests naturally, sauce drips flow downward. Zero floating. 100% photorealistic. MOOD: Premium casual.`,
  'Steak & Fire-Grilled': `CAMERA: 25-35 degree angle. LIGHTING: 2800K dramatic. SURFACE: Dark slate. CRUST: Maillard visible. PHYSICS & REALISM: Steak rests naturally, juices pool with gravity. Zero floating. 100% photorealistic. MOOD: Steakhouse premium.`,
  'Pasta & Risotto Bowl': `CAMERA: 40-50 degree angle. LIGHTING: 4000K warm. SURFACE: Ceramic bowl. SAUCE: Coating visible. PHYSICS & REALISM: Pasta rests naturally, sauce flows downward. Zero floating. 100% photorealistic. MOOD: Italian trattoria.`,
  'Soup & Broth Bowl': `CAMERA: 65-75 degree overhead. LIGHTING: 5000K backlit. SURFACE: Premium ceramic. BROTH: Translucent glow. STEAM: Rising vertically. PHYSICS & REALISM: Bowl rests naturally, ingredients float by density. Zero floating. 100% photorealistic. MOOD: Tokyo ramen bar.`,
};

export const BUTTON_PROMPTS: Record<string, string> = {
  'pizza quattro formaggi': `Pizza Quattro Formaggi — four cheese pizza. STYLE: Pizza Overhead. ANGLE: 90deg overhead. PHYSICS: Pizza rests naturally, cheese melt flows downward. Zero floating. 100% photorealistic.`,
  'magic edit': `Edit image based on: "{userPrompt}". New elements integrate naturally with correct lighting/shadow. PHYSICS: All added elements rest naturally. Zero floating. 100% photorealistic.`,
  'add logo': `Integrate logo naturally on napkin/coaster. Logo has realistic material texture. PHYSICS: Logo object rests naturally. Zero floating. 100% photorealistic.`,
  'prep team': `Miniature 1:10 construction crew preparing dish. 4-5 realistic people in helmets. Dish appears massive. PHYSICS: Mini people cast tiny shadows, dish rests naturally. Zero floating. 100% photorealistic.`,
  'detection squad': `Miniature 1:10 detective squad investigating dish as crime scene. Yellow police tape around. PHYSICS: Tape rests naturally with sag, dish has contact shadow. Zero floating. 100% photorealistic.`,
};

export function getStylePrompt(key: string) { return STYLE_PROMPTS[key] || STYLE_PROMPTS['Pizza Overhead']; }
export function getButtonPrompt(key: string, prompt?: string) { return BUTTON_PROMPTS[key.toLowerCase()]?.replace('{userPrompt}', prompt || '') || ''; }
