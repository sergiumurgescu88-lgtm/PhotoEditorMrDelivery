export async function generateDishImage(prompt: string, dishName: string, style: string): Promise<{imageUrl: string; provider: string}> {
  const stylePrompt = STYLE_PROMPTS[style] || STYLE_PROMPTS["Pizza Michelin"];
  const fullPrompt = prompt + ". " + stylePrompt;
  try {
    const response = await fetch("/api/generate", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({prompt: fullPrompt, dishName, style})
    });
    const data = await response.json();
    return {imageUrl: data.imageUrl, provider: data.provider || "kie.ai"};
  } catch (e) {
    console.error("Generate error:", e);
    return {imageUrl: "", provider: "error"};
  }
}

export async function editDishImage(imageUrl: string, editPrompt: string): Promise<{imageUrl: string}> {
  try {
    const response = await fetch("/api/edit", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({imageUrl, editPrompt})
    });
    return await response.json();
  } catch (e) {
    console.error("Edit error:", e);
    return {imageUrl};
  }
}

export async function analyzeDishNutrition(dishName: string, description: string): Promise<any> {
  return {
    per100g: {calories: 285, protein: 12.5, carbs: 32.1, fat: 11.8, fiber: 2.3, sugar: 4.1},
    perServing: {calories: 420, protein: 18, carbs: 48, fat: 17, fiber: 3.5, sugar: 6},
    allergens: ["gluten", "lactate", "oua"],
    dietaryInfo: ["vegetarian"],
    servingSize: "350g"
  };
}

export function getStylePrompt(key: string): string { return STYLE_PROMPTS[key] || STYLE_PROMPTS["Pizza Michelin"]; }
export function getButtonPrompt(key: string, prompt?: string): string { 
  const base = (BUTTON_PROMPTS as any)[key.toLowerCase()]; 
  return base ? base.replace("{userPrompt}", prompt || "") : ""; 
}
export function detectCategory(dishName: string): string {
  const n = dishName.toLowerCase();
  if (n.includes("pizza")) return "Pizza Michelin";
  if (n.includes("burger") || n.includes("sandwich")) return "Burger Hero";
  if (n.includes("steak") || n.includes("rib") || n.includes("bbq")) return "Steak Maillard";
  if (n.includes("pasta") || n.includes("risotto")) return "Pasta Nest";
  if (n.includes("soup") || n.includes("ramen")) return "Soup Gourmet";
  if (n.includes("seafood") || n.includes("fish") || n.includes("shrimp")) return "Seafood Shellfish";
  if (n.includes("sushi") || n.includes("asian")) return "Asian Precision";
  if (n.includes("salad") || n.includes("bowl")) return "Salad Freshness";
  if (n.includes("breakfast") || n.includes("brunch")) return "Breakfast Elite";
  if (n.includes("mexican") || n.includes("taco")) return "Mexican Vibrant";
  if (n.includes("appetizer") || n.includes("board")) return "Appetizer Board";
  if (n.includes("cake") || n.includes("patisserie")) return "Cake Layers";
  if (n.includes("dessert")) return "Plated Dessert";
  if (n.includes("ice cream") || n.includes("gelato")) return "Ice Cream Frozen";
  if (n.includes("cocktail") || n.includes("drink")) return "Cocktail Craft";
  if (n.includes("bottle") || n.includes("wine") || n.includes("beer")) return "Bottle Product";
  if (n.includes("coffee") || n.includes("latte") || n.includes("tea")) return "Hot Beverages";
  if (n.includes("fries") || n.includes("fried")) return "Street Food Casual";
  if (n.includes("vegan") || n.includes("plant")) return "Plant Wellness";
  if (n.includes("bread") || n.includes("bakery")) return "Bread Artisan";
  if (n.includes("cheese") || n.includes("charcuterie")) return "Cheese Charcuterie";
  return "Pizza Michelin";
}

export async function chatWithConcierge(message: string, context?: any): Promise<{reply: string}> {
  return {reply: "Concierge: Am primit mesajul tau. Iti raspund in curand!"};
}
export function speakText(text: string): void {
  if ("speechSynthesis" in window) {
    const u = new SpeechSynthesisUtterance(text);
    u.lang = "ro-RO";
    u.rate = 0.9;
    window.speechSynthesis.speak(u);
  }
}
export async function sendLiveConciergeMessage(message: string, imageData?: string): Promise<{success: boolean; reply?: string}> {
  console.log("Live concierge:", message, imageData ? "[image]" : "");
  return {success: true, reply: "Mesaj trimis!"};
}
