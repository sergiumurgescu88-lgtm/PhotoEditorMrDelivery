export const PREP_TEAM_PROMPT="Mini 1:10 construction crew.4-5 realistic people helmets.Dish massive.Warm lighting.PHYSICS:tiny shadows,zero floating.100% photorealistic.";
export const DETECTION_SQUAD_PROMPT="Mini 1:10 detective squad.Yellow police tape.Film-noir lighting.PHYSICS:tape sag,zero floating.100% photorealistic.";
export async function generateDishImage(p:string,d:string,s:string){const sp=STYLE_PROMPTS[s]||STYLE_PROMPTS["Pizza Michelin"];const fp=p+". "+sp;const r=await fetch("/api/generate",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({prompt:fp,dishName:d,style:s})});return await r.json();}
export async function editDishImage(iu:string,ep:string){const r=await fetch("/api/edit",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({imageUrl:iu,editPrompt:ep})});return await r.json();}
export async function addLogoToImage(iu:string,lu:string,pl:string="napkin"){const r=await fetch("/api/logo",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({imageUrl:iu,logoUrl:lu,placement:pl})});return await r.json();}
export async function analyzeDishNutrition(dn:string,desc:string){return{per100g:{calories:285,protein:12.5,carbs:32.1,fat:11.8},allergens:["gluten","lactate"],servingSize:"350g"};}
export function getStylePrompt(k:string){return STYLE_PROMPTS[k]||STYLE_PROMPTS["Pizza Michelin"]}
export function getButtonPrompt(k:string,p?:string){const b=(BUTTON_PROMPTS as any)[k.toLowerCase()];return b?b.replace("{userPrompt}",p||""):""}
export function detectCategory(dn:string){const n=dn.toLowerCase();if(n.includes("pizza"))return"Pizza Michelin";if(n.includes("burger")||n.includes("sandwich"))return"Burger Hero";if(n.includes("steak")||n.includes("rib"))return"Steak Maillard";if(n.includes("pasta")||n.includes("risotto"))return"Pasta Nest";if(n.includes("soup")||n.includes("ramen"))return"Soup Gourmet";return"Pizza Michelin";}
export async function chatWithConcierge(m:string){return{reply:"Concierge: Mesaj primit. Răspund curând."}}
export function speakText(t:string){if("speechSynthesis"in window){const u=new SpeechSynthesisUtterance(t);u.lang="ro-RO";window.speechSynthesis.speak(u)}}
